# Supabase (shared instance across all SOS projects)
NEXT_PUBLIC_SUPABASE_URL=https://jnbxkvlkqmwnqlmetknj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: override email redirect URL for local development
# Falls back to ${window.location.origin}/auth/callback if not set
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# App URL (used for email links and Stripe redirect URLs)
# NEXT_PUBLIC_APP_URL=https://safe.tourist-sos.com

# Anthropic (for SOSA AI chat — set via Vercel integration or manually)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Supabase service role key (required for /admin dashboard — bypasses RLS)
# Find this in Supabase → Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin access — comma-separated emails allowed to access /admin
# ADMIN_EMAILS=you@example.com,cofounder@example.com

# ── Stripe (subscription billing) ──────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in Stripe Dashboard, then paste price IDs here
# Each property type needs a monthly + annual price
# STRIPE_PRICE_HOSTEL_MONTHLY=price_...
# STRIPE_PRICE_HOSTEL_ANNUAL=price_...
# STRIPE_PRICE_GUESTHOUSE_MONTHLY=price_...
# STRIPE_PRICE_GUESTHOUSE_ANNUAL=price_...
# STRIPE_PRICE_HOTEL_MONTHLY=price_...
# STRIPE_PRICE_HOTEL_ANNUAL=price_...
# STRIPE_PRICE_TOUR_OPERATOR_MONTHLY=price_...
# STRIPE_PRICE_TOUR_OPERATOR_ANNUAL=price_...

# ── Resend (transactional emails) ──────────────────────────────────
# Get your API key from https://resend.com/api-keys
# Email delivery is optional — logs to console if not set
# RESEND_API_KEY=re_...
